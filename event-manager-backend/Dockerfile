# 1. كَانْأَخْدُو إِيمِيجْ فِيهَا غِير الـ Java 17 خْفِيفَة بَاشْ تّْشَّغَّلْ الـ كُودْ
FROM eclipse-temurin:17-jdk-alpine

# 2. كَانْحَدُّو الـ دُّوسِي د الـخِدْمَة لْدَاخْلْ وسط الـ الـContainer
WORKDIR /app

# 3. كَانْكُوبِيوْ الـ مَلَفْ `.jar` لِي صَاوْبْ لِيكْ جِينْكِينْزْ ف الـ target ونْحُطُّوهْ وسط الـ Image
COPY target/*.jar app.jar

# 4. الـ بُّورْتْ لِي كَايْخْدْمْ فِيهْ الـ backend دْيَالْكْ (مَثَلاً 8080 أو 4000)
EXPOSE 8080

# 5. الـ كُومُونْدْ لِي كَتْشَعّْلْ الـ بروجي فَّاشْ كَايْنْطَالْقْ الـ Container
ENTRYPOINT ["java", "-jar", "app.jar"]